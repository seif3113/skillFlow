{
  "buildCommand": "vite build",
  "installCommand": "bun install",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/auth/:path*",
      "destination": "https://skill-flow-api.vercel.app/api/auth/:path*"
    },
    {
      "source": "/graphql",
      "destination": "https://skill-flow-api.vercel.app/graphql"
    }
  ]
}
